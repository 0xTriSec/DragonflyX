# DragonflyX - API Keys Configuration
# Copy this file to .env and fill in your keys

# VirusTotal - https://virustotal.com - 4 req/min free tier
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB - https://abuseipdb.com - 1,000 req/day free tier
AB_API_KEY=your_abuseipdb_api_key_here

# URLScan.io - https://urlscan.io - 100 req/day free tier
URLSCAN_IO_KEY=your_urlscan_api_key_here

# Shodan - https://shodan.io - 100 req/month free tier
SHODAN_API_KEY=your_shodan_api_key_here

# Paste Search - psbdmp.ws - no API key required (public API)
# Used by: dragonflyx paste <target>
